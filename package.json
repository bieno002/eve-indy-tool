{
  "name": "eve-indy-tool",
  "version": "1.0.0",
  "description": "Tool to see what things can be built with current material stock in Eve Online.",
  "license": "ISC",
  "author": "Jerrad Bieno",
  "type": "commonjs",
  "main": "dist/electron/main.js",
  "scripts": {
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:integration": "vitest run --project integration --passWithNoTests",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && npm run build:electron && VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev": "concurrently -k -n vite,electron \"npm:dev:vite\" \"npm:dev:electron\"",
    "setup-sde": "tsx scripts/downloadSde.ts",
    "rebuild": "electron-rebuild",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:renderer": "vite build",
    "build": "npm run clean && npm run build:electron && npm run build:renderer",
    "start": "npm run build && electron .",
    "typecheck": "tsc -b && tsc -p tsconfig.renderer.json",
    "clean": "rimraf dist",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "package": "npm run build && electron-builder",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win",
    "package:linux": "npm run build && electron-builder --linux"
  },
  "build": {
    "appId": "com.jerradbieno.eve-indy-tool",
    "productName": "EVE Industry Tool",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] }
      ],
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "buffer-crc32": "^0.2.13",
    "debug": "^4.4.3",
    "end-of-stream": "^1.4.5",
    "env-paths": "^3.0.0",
    "extract-zip": "^2.0.1",
    "fd-slicer": "^1.1.0",
    "get-stream": "^5.2.0",
    "graceful-fs": "^4.2.11",
    "ms": "^2.1.3",
    "once": "^1.4.0",
    "pend": "^1.2.0",
    "progress": "^2.0.3",
    "pump": "^3.0.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "semver": "^7.8.0",
    "sumchecker": "^3.0.1",
    "unbzip2-stream": "^1.4.3",
    "undici": "^7.25.0",
    "undici-types": "^7.16.0",
    "wrappy": "^1.0.2",
    "yauzl": "^2.10.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.6",
    "concurrently": "^9.2.1",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.13",
    "vitest": "^4.1.6",
    "wait-on": "^9.0.10"
  }
}
